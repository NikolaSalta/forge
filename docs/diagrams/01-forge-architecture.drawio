        <!-- Core → Retrieval -->
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;strokeColor=#6c8ebf;" edge="1" source="core" target="retrieval" parent="1">
