        <!-- Evolution → Storage -->
        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;strokeColor=#9673a6;" edge="1" source="evolution" target="storage" parent="1">
          <mxGeometry relative="1" as="geometry" />
