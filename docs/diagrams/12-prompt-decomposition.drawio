<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="draw.io">
  <diagram name="Prompt Decomposition Flow" id="pdc-012">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="Prompt Decomposition Flow" style="text;html=1;fontSize=20;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="300" y="10" width="500" height="40" as="geometry" />
        </mxCell>

        <!-- User Prompt -->
        <mxCell id="prompt" value="&lt;b&gt;User Prompt&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="430" y="60" width="180" height="45" as="geometry" />
        </mxCell>

        <!-- PromptAnalyzer -->
        <mxCell id="analyzer" value="&lt;b&gt;PromptAnalyzer&lt;/b&gt;&lt;br&gt;(Heuristic Layer)&lt;br&gt;&lt;br&gt;Keyword detection, sentence count,&lt;br&gt;conjunction analysis, scope estimation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="380" y="130" width="280" height="100" as="geometry" />
        </mxCell>

        <!-- PromptComplexity -->
        <mxCell id="complexity" value="&lt;b&gt;PromptComplexity&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="455" y="270" width="130" height="80" as="geometry" />
        </mxCell>

        <mxCell id="ep1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;endArrow=block;endFill=1;strokeWidth=2;" edge="1" source="prompt" target="analyzer" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ep2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;endArrow=block;endFill=1;strokeWidth=2;" edge="1" source="analyzer" target="complexity" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- SIMPLE path -->
        <mxCell id="simple_label" value="&lt;b&gt;SIMPLE&lt;/b&gt;" style="text;html=1;fontSize=12;fontStyle=1;fillColor=#d5e8d4;strokeColor=#82b366;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="295" width="80" height="25" as="geometry" />
        </mxCell>

        <mxCell id="direct" value="&lt;b&gt;Direct Execute&lt;/b&gt;&lt;br&gt;Single pipeline run&lt;br&gt;No decomposition needed" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="50" y="350" width="200" height="60" as="geometry" />
        </mxCell>

        <mxCell id="simple_out" value="&lt;b&gt;Response&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="85" y="450" width="130" height="40" as="geometry" />
        </mxCell>

        <mxCell id="es1" value="SIMPLE" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;endArrow=block;endFill=1;fontStyle=1;fontSize=10;strokeColor=#82b366;" edge="1" source="complexity" target="direct" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="es2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;endArrow=block;endFill=1;" edge="1" source="direct" target="simple_out" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- COMPOUND path -->
        <mxCell id="compound_label" value="&lt;b&gt;COMPOUND&lt;/b&gt;" style="text;html=1;fontSize=12;fontStyle=1;fillColor=#f8cecc;strokeColor=#b85450;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="700" y="295" width="100" height="25" as="geometry" />
        </mxCell>

        <!-- ExecutionPlanner -->
        <mxCell id="planner" value="&lt;b&gt;ExecutionPlanner&lt;/b&gt;&lt;br&gt;&lt;br&gt;Decompose into sub-tasks,&lt;br&gt;determine execution order,&lt;br&gt;identify dependencies" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="650" y="340" width="220" height="100" as="geometry" />
        </mxCell>

        <mxCell id="ec1" value="COMPOUND" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;endArrow=block;endFill=1;fontStyle=1;fontSize=10;strokeColor=#b85450;" edge="1" source="complexity" target="planner" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Execution Layers -->
        <mxCell id="layers_title" value="&lt;b&gt;Execution Layers&lt;/b&gt;" style="text;html=1;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="350" y="470" width="150" height="25" as="geometry" />
        </mxCell>

        <mxCell id="layer1" value="&lt;b&gt;Layer 1&lt;/b&gt; (independent)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="350" y="500" width="140" height="35" as="geometry" />
        </mxCell>
        <mxCell id="layer2" value="&lt;b&gt;Layer 2&lt;/b&gt; (depends on L1)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="510" y="500" width="140" height="35" as="geometry" />
        </mxCell>
        <mxCell id="layer3" value="&lt;b&gt;Layer N&lt;/b&gt; (depends on L2)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="670" y="500" width="140" height="35" as="geometry" />
        </mxCell>

        <mxCell id="el1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;endArrow=block;endFill=1;" edge="1" source="planner" target="layer1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="760" y="460" />
              <mxPoint x="420" y="460" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="el2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;endArrow=block;endFill=1;" edge="1" source="layer1" target="layer2" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="el3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;endArrow=block;endFill=1;" edge="1" source="layer2" target="layer3" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ParallelExecutor -->
        <mxCell id="parallel" value="&lt;b&gt;ParallelExecutor&lt;/b&gt;&lt;br&gt;(Semaphore-based)&lt;br&gt;&lt;br&gt;Run sub-tasks within each&lt;br&gt;layer concurrently, wait for&lt;br&gt;all before next layer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="350" y="560" width="200" height="100" as="geometry" />
        </mxCell>

        <!-- Partition Results -->
        <mxCell id="partition" value="&lt;b&gt;Partition Results&lt;/b&gt;&lt;br&gt;Group outputs by&lt;br&gt;sub-task origin" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="600" y="570" width="150" height="60" as="geometry" />
        </mxCell>

        <!-- Reconciler -->
        <mxCell id="reconciler" value="&lt;b&gt;Reconciler&lt;/b&gt;&lt;br&gt;Resolve conflicts,&lt;br&gt;merge overlaps" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="790" y="570" width="150" height="60" as="geometry" />
        </mxCell>

        <!-- ResultSynthesizer -->
        <mxCell id="synthesizer" value="&lt;b&gt;ResultSynthesizer&lt;/b&gt;&lt;br&gt;Combine all sub-results&lt;br&gt;into coherent final output" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="600" y="680" width="200" height="60" as="geometry" />
        </mxCell>

        <!-- Final Output -->
        <mxCell id="final" value="&lt;b&gt;Final Output&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="350" y="690" width="150" height="40" as="geometry" />
        </mxCell>

        <mxCell id="ep3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;endArrow=block;endFill=1;" edge="1" source="layer1" target="parallel" parent="1">
          <mxGeometry relative="1" as="geometry">
