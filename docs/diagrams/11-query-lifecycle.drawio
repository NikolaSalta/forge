        <mxCell id="e11" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;endArrow=block;endFill=1;strokeWidth=2;dashed=1;" edge="1" source="sse" target="browser" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Legend -->
        <mxCell id="leg_solid" value="— Request flow" style="text;html=1;fontSize=10;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="400" width="120" height="20" as="geometry" />
