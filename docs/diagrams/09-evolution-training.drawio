        <mxCell id="scorer" value="&lt;b&gt;QualityScorer&lt;/b&gt;&lt;br&gt;Score: 0.0 - 1.0&lt;br&gt;Heuristic + LLM judge" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
