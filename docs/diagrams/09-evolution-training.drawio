        <mxCell id="collector" value="&lt;b&gt;TrainingDataCollector&lt;/b&gt;&lt;br&gt;Captures query-response pairs&lt;br&gt;with metadata and context" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
