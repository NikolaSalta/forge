        </mxCell>
        <mxCell id="filter" value="&lt;b&gt;TrainingDataFilter&lt;/b&gt;&lt;br&gt;Threshold: &amp;gt; 0.7&lt;br&gt;Dedup, balance" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
