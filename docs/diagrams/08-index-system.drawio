<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="draw.io">
  <diagram name="Index System" id="idx-008">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="ProjectIndexCoordinator — Index System" style="text;html=1;fontSize=20;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="250" y="10" width="600" height="40" as="geometry" />
        </mxCell>

        <!-- Phase 1 -->
        <mxCell id="p1" value="&lt;b&gt;Phase 1: File Classification&lt;/b&gt;&lt;br&gt;&lt;br&gt;Scan project files, classify by&lt;br&gt;language, type (source, config,&lt;br&gt;test, docs), detect framework" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="50" y="70" width="200" height="110" as="geometry" />
        </mxCell>

        <!-- Phase 2 -->
        <mxCell id="p2" value="&lt;b&gt;Phase 2: Entity Extraction&lt;/b&gt;&lt;br&gt;&lt;br&gt;Extract: classes, interfaces,&lt;br&gt;methods, functions, properties,&lt;br&gt;enums, data classes" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="290" y="70" width="200" height="110" as="geometry" />
        </mxCell>

        <!-- Phase 3 -->
        <mxCell id="p3" value="&lt;b&gt;Phase 3: Relationship Graph&lt;/b&gt;&lt;br&gt;&lt;br&gt;Map: imports, extends,&lt;br&gt;implements, calls,&lt;br&gt;references, annotations" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="530" y="70" width="200" height="110" as="geometry" />
        </mxCell>

        <!-- Phase 4 -->
        <mxCell id="p4" value="&lt;b&gt;Phase 4: Line Index&lt;/b&gt;&lt;br&gt;&lt;br&gt;Per-line entity mapping:&lt;br&gt;line 42 → MyClass.doThing()&lt;br&gt;Enables precise navigation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="770" y="70" width="200" height="110" as="geometry" />
        </mxCell>

        <!-- Phase 5 -->
        <mxCell id="p5" value="&lt;b&gt;Phase 5: Dependency Graph&lt;/b&gt;&lt;br&gt;&lt;br&gt;Module-level dependencies&lt;br&gt;via JOIN across files and&lt;br&gt;entity relationships" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="200" y="230" width="220" height="110" as="geometry" />
        </mxCell>

        <!-- Phase 6 -->
        <mxCell id="p6" value="&lt;b&gt;Phase 6: Metadata Persistence&lt;/b&gt;&lt;br&gt;&lt;br&gt;Write all indexed data to&lt;br&gt;SQLite database tables,&lt;br&gt;update timestamps" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="530" y="230" width="220" height="110" as="geometry" />
        </mxCell>

        <!-- Arrows between phases -->
        <mxCell id="ep1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;endArrow=block;endFill=1;strokeWidth=2;" edge="1" source="p1" target="p2" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ep2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;endArrow=block;endFill=1;strokeWidth=2;" edge="1" source="p2" target="p3" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ep3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;endArrow=block;endFill=1;strokeWidth=2;" edge="1" source="p3" target="p4" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ep4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;endArrow=block;endFill=1;strokeWidth=2;" edge="1" source="p4" target="p5" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="870" y="200" />
              <mxPoint x="310" y="200" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="ep5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;endArrow=block;endFill=1;strokeWidth=2;" edge="1" source="p5" target="p6" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- SQLite Tables -->
        <mxCell id="db_title" value="&lt;b&gt;SQLite Database Tables&lt;/b&gt;" style="text;html=1;fontSize=14;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="300" y="390" width="400" height="30" as="geometry" />
        </mxCell>

        <mxCell id="t1" value="&lt;b&gt;files&lt;/b&gt;&lt;br&gt;id, path, language,&lt;br&gt;type, hash, last_indexed" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="430" width="170" height="65" as="geometry" />
        </mxCell>
        <mxCell id="t2" value="&lt;b&gt;entities&lt;/b&gt;&lt;br&gt;id, file_id, name, kind,&lt;br&gt;start_line, end_line, signature" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="240" y="430" width="180" height="65" as="geometry" />
        </mxCell>
        <mxCell id="t3" value="&lt;b&gt;entity_relationships&lt;/b&gt;&lt;br&gt;source_id, target_id,&lt;br&gt;relationship_type" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="440" y="430" width="170" height="65" as="geometry" />
        </mxCell>
        <mxCell id="t4" value="&lt;b&gt;line_index&lt;/b&gt;&lt;br&gt;file_id, line_number,&lt;br&gt;entity_id" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="630" y="430" width="170" height="65" as="geometry" />
        </mxCell>
        <mxCell id="t5" value="&lt;b&gt;dependencies&lt;/b&gt;&lt;br&gt;source_module, target_module,&lt;br&gt;dep_type" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="820" y="430" width="170" height="65" as="geometry" />
        </mxCell>

        <!-- Phase 6 → all tables -->
        <mxCell id="et1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;endArrow=block;endFill=1;strokeColor=#b85450;dashed=1;" edge="1" source="p6" target="t1" parent="1">
