<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="draw.io">
  <diagram name="Configuration Loading Flow" id="cfg-006">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="Configuration Loading Flow" style="text;html=1;fontSize=20;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="300" y="10" width="500" height="40" as="geometry" />
        </mxCell>

        <!-- Default config -->
        <mxCell id="default" value="&lt;b&gt;forge-default.yaml&lt;/b&gt;&lt;br&gt;(classpath resource)&lt;br&gt;&lt;br&gt;Built-in defaults for&lt;br&gt;all configuration keys" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="50" y="80" width="200" height="110" as="geometry" />
        </mxCell>

        <!-- User config -->
        <mxCell id="user" value="&lt;b&gt;~/.forge/forge.yaml&lt;/b&gt;&lt;br&gt;(user override)&lt;br&gt;&lt;br&gt;Custom settings per user,&lt;br&gt;optional file" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="50" y="230" width="200" height="110" as="geometry" />
        </mxCell>

        <!-- ForgeConfig.load() -->
        <mxCell id="loader" value="&lt;b&gt;ForgeConfig.load()&lt;/b&gt;&lt;br&gt;&lt;br&gt;1. Load defaults&lt;br&gt;2. Load user overrides&lt;br&gt;3. Deep merge (user wins)&lt;br&gt;4. Validate required fields" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="370" y="120" width="220" height="130" as="geometry" />
        </mxCell>

        <!-- ForgeConfig object -->
        <mxCell id="config" value="&lt;b&gt;ForgeConfig&lt;/b&gt;&lt;br&gt;(merged object)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="700" y="155" width="200" height="60" as="geometry" />
        </mxCell>

        <!-- Sub-configs -->
        <mxCell id="sc1" value="&lt;b&gt;OllamaConfig&lt;/b&gt;&lt;br&gt;host, port, timeout" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="620" y="280" width="150" height="50" as="geometry" />
        </mxCell>
        <mxCell id="sc2" value="&lt;b&gt;ModelsConfig&lt;/b&gt;&lt;br&gt;classifier, reasoner, specialists" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="790" y="280" width="180" height="50" as="geometry" />
        </mxCell>
        <mxCell id="sc3" value="&lt;b&gt;AgentOrchestrationConfig&lt;/b&gt;&lt;br&gt;memory budget, swap strategy" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="620" y="350" width="180" height="50" as="geometry" />
        </mxCell>
        <mxCell id="sc4" value="&lt;b&gt;PipelineConfig&lt;/b&gt;&lt;br&gt;stages, concurrency" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="820" y="350" width="150" height="50" as="geometry" />
        </mxCell>
        <mxCell id="sc5" value="&lt;b&gt;WebConfig&lt;/b&gt;&lt;br&gt;port, host, cors" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="620" y="420" width="150" height="50" as="geometry" />
        </mxCell>
        <mxCell id="sc6" value="&lt;b&gt;EvolutionConfig&lt;/b&gt;&lt;br&gt;quality threshold, export format" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="790" y="420" width="180" height="50" as="geometry" />
        </mxCell>

        <!-- Arrows -->
        <mxCell id="e1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;endArrow=block;endFill=1;strokeColor=#6c8ebf;strokeWidth=2;" edge="1" source="default" target="loader" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;endArrow=block;endFill=1;strokeColor=#d6b656;strokeWidth=2;" edge="1" source="user" target="loader" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" value="merge" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;endArrow=block;endFill=1;strokeColor=#82b366;strokeWidth=2;fontStyle=1;" edge="1" source="loader" target="config" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Config → sub-configs -->
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;endArrow=block;endFill=1;strokeColor=#9673a6;" edge="1" source="config" target="sc1" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;endArrow=block;endFill=1;strokeColor=#9673a6;" edge="1" source="config" target="sc2" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;endArrow=block;endFill=1;strokeColor=#9673a6;" edge="1" source="config" target="sc3" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;endArrow=block;endFill=1;strokeColor=#9673a6;" edge="1" source="config" target="sc4" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;endArrow=block;endFill=1;strokeColor=#9673a6;" edge="1" source="config" target="sc5" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;endArrow=block;endFill=1;strokeColor=#9673a6;" edge="1" source="config" target="sc6" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Priority note -->
        <mxCell id="note" value="Priority: User config overrides defaults.&lt;br&gt;Missing user keys fall back to defaults." style="text;html=1;fontSize=11;fontStyle=2;align=center;fillColor=#f5f5f5;rounded=1;strokeColor=#CCCCCC;" vertex="1" parent="1">
          <mxGeometry x="100" y="380" width="300" height="40" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
